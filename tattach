#!/bin/sh
#
# Attach or create tmux session named the same as current directory.
#
# When the tmux server is not yet running, start it bare and wait for
# tmux-continuum to finish restoring before attaching. Creating a session
# with `new-session -As` in that window would race the restore and leave
# you with an empty session.

path_name="$(basename "$PWD" | tr . -)"
session_name=${1-$path_name}

server_running() {
  tmux info >/dev/null 2>&1
}

session_exists() {
  tmux has-session -t "=$session_name" 2>/dev/null
}

any_session_exists() {
  [ -n "$(tmux list-sessions -F '#S' 2>/dev/null)" ]
}

wait_for_continuum_restore() {
  # continuum_restore.sh sleeps 1s then runs resurrect; poll up to ~8s.
  # The initial sleep also keeps our polling `tmux` processes out of the
  # window where continuum counts tmux processes on startup — extra clients
  # at that moment make it silently skip the restore.
  sleep 1
  i=0
  while [ "$i" -lt 16 ]; do
    if any_session_exists; then
      return 0
    fi
    sleep 0.5
    i=$((i + 1))
  done
  return 1
}

create_detached_session() {
  (TMUX='' tmux new-session -Ad -s "$session_name")
}

if [ -z "$TMUX" ]; then
  if ! server_running; then
    tmux start-server
    wait_for_continuum_restore
  fi

  if session_exists; then
    tmux attach -t "$session_name"
  elif any_session_exists; then
    tmux attach
  else
    tmux new-session -As "$session_name"
  fi
else
  if ! session_exists; then
    create_detached_session
  fi
  tmux switch-client -t "$session_name"
fi
